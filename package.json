{
  "name": "project-md",
  "version": "1.0.3",
  "private": true,
  "description": "Electron desktop app for managing a local project.md markdown file.",
  "author": "bybunni",
  "type": "module",
  "homepage": "https://github.com/bybunni/project.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bybunni/project.md.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "electron .",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "test": "node --test"
  },
  "dependencies": {
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "svelte": "^4.2.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.projectmd.desktop",
    "productName": "project.md",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "lib/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
